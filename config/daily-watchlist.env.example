# Daily Watchlist environment file
# Copy this file to daily-watchlist.env and fill in your keys.

# Required: Financial Modeling Prep — https://site.financialmodelingprep.com/register
FMP_API_KEY=your_fmp_api_key_here

# Optional: Tushare Pro — https://tushare.pro/register
# For A-shares (.SH/.SZ) and HK (.HK) tickers
TUSHARE_TOKEN=

# --- Fallback sources (all optional) ---
# The script auto-falls-back to these when FMP doesn't return a ticker.
# Stooq is always on for US/JP/DE and needs no key.

# Optional: Finnhub — https://finnhub.io/register
# US-only fallback when FMP returns nothing. Free tier: 60 req/min.
FINNHUB_API_KEY=

# Optional: EOD Historical Data — https://eodhd.com/
# Fallback for HK/KR/FI (markets Stooq + Tushare don't cover well).
# Free tier: 20 req/day.
EOD_API_KEY=

# Optional: yfinance (unofficial Yahoo Finance)
# Set to 1 to enable. Also requires: pip install yfinance
# NOTE: often unreliable from mainland China — use a stable VPN or keep disabled.
ENABLE_YFINANCE=
